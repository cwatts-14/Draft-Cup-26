{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build:server": "esbuild server.ts --bundle --platform=node --format=esm --outfile=server.js --external:express --external:vite --external:ws --external:path --external:url",
    "build": "vite build && npm run build:server",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "start": "node server.js"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.4",
    "country-flag-icons": "^1.6.15",
    "dotenv": "^17.2.3",
    "esbuild": "^0.27.4",
    "express": "^4.21.2",
    "firebase": "^12.11.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.2",
    "tsx": "^4.21.0",
    "vite": "^6.2.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
